{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "sortTailwindcss": {},
  "trailingComma": "all",
  "quoteProps": "consistent",
  "tabWidth": 2,
  "semi": false,
  "singleQuote": true,
  "singleAttributePerLine": true,
  "bracketSameLine": true,
  "endOfLine": "lf",
  "importOrder": ["<BUILTIN_MODULES>", "", "<THIRD_PARTY_MODULES>", "", "^@/(.*)$", "", "^[./]"],
  "importOrderParserPlugins": ["typescript"],
  "importOrderTypeScriptVersion": "5.2.2",
  "printWidth": 80,
  "sortPackageJson": false,
  "ignorePatterns": [
    "*.js",
    "*.ts",
    "*.tsx",
    "*.json",
    "!package.json",
    "*.jsonc",
    "*.mov",
    "*.cjs",
    ".git",
    ".venv",
    "**/.nuxt/**",
    "**/.next/**",
    "**/.turbo/**",
    "**/dist/**",
    "**/.vscode/**",
    "**/.output/**",
    "**/.docusaurus/**",
    "**/obj/**",
    "**/bin/**",
    "**/target/**",
    "**/.vite-ssg-temp/**",
    "**/vite.config.ts.timestamp-*.mjs",
    "fixtures",
    "node_modules",
    "playwright-report",
    "scalar.config.json",
    "pnpm-lock.yaml",
    "cdn",
    "cloudbuild.json",
    ".changeset/*.md",
    "integrations/docusaurus/**/*.mdx",
    "integrations/docusaurus/playground/build/**",
    "integrations/docker/assets/**",
    "integrations/nuxt/src/runtime/plugins/hydrateClient.d.mts",
    "packages/components/storybook-static/**/*",
    "packages/openapi-parser/tests/**/*.yaml"
  ]
}
