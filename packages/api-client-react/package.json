{
  "name": "@scalar/api-client-react",
  "description": "the open source API testing client for react",
  "license": "MIT",
  "author": "Scalar (https://github.com/scalar)",
  "homepage": "https://github.com/scalar/scalar",
  "bugs": "https://github.com/scalar/scalar/issues/new/choose",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scalar/scalar.git",
    "directory": "packages/api-client-react"
  },
  "keywords": [
    "api",
    "client",
    "graphql",
    "postman alternative",
    "rest",
    "testing",
    "react"
  ],
  "version": "2.0.8",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.build.json",
    "dev": "vite ./playground -c ./vite.config.ts",
    "test": "vitest --run",
    "types:check": "vue-tsc --noEmit"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@scalar/api-client": "workspace:*",
    "@scalar/helpers": "workspace:*",
    "@scalar/workspace-store": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "catalog:*",
    "@types/react-dom": "catalog:*",
    "@vitejs/plugin-react": "catalog:*",
    "jsdom": "^29.0.1",
    "react": "catalog:*",
    "react-dom": "catalog:*",
    "rollup-preserve-directives": "^1.1.1",
    "vite": "catalog:*",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  }
}
