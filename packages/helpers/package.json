{
  "name": "@scalar/helpers",
  "description": "A collection of dependency free helpers",
  "license": "MIT",
  "author": "Scalar (https://github.com/scalar)",
  "homepage": "https://github.com/scalar/scalar",
  "bugs": "https://github.com/scalar/scalar/issues/new/choose",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scalar/scalar.git",
    "directory": "packages/helpers"
  },
  "keywords": [
    "helpers",
    "js"
  ],
  "version": "0.4.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "test": "vitest --run",
    "types:check": "tsc --noEmit"
  },
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "exports": {
    "./array/*": {
      "import": "./dist/array/*.js",
      "types": "./dist/array/*.d.ts",
      "default": "./dist/array/*.js"
    },
    "./crypto/*": {
      "import": "./dist/crypto/*.js",
      "types": "./dist/crypto/*.d.ts",
      "default": "./dist/crypto/*.js"
    },
    "./dom/*": {
      "import": "./dist/dom/*.js",
      "types": "./dist/dom/*.d.ts",
      "default": "./dist/dom/*.js"
    },
    "./errors/*": {
      "import": "./dist/errors/*.js",
      "types": "./dist/errors/*.d.ts",
      "default": "./dist/errors/*.js"
    },
    "./file/*": {
      "import": "./dist/file/*.js",
      "types": "./dist/file/*.d.ts",
      "default": "./dist/file/*.js"
    },
    "./formatters/*": {
      "import": "./dist/formatters/*.js",
      "types": "./dist/formatters/*.d.ts",
      "default": "./dist/formatters/*.js"
    },
    "./general/*": {
      "import": "./dist/general/*.js",
      "types": "./dist/general/*.d.ts",
      "default": "./dist/general/*.js"
    },
    "./http/*": {
      "import": "./dist/http/*.js",
      "types": "./dist/http/*.d.ts",
      "default": "./dist/http/*.js"
    },
    "./json/*": {
      "import": "./dist/json/*.js",
      "types": "./dist/json/*.d.ts",
      "default": "./dist/json/*.js"
    },
    "./markdown/*": {
      "import": "./dist/markdown/*.js",
      "types": "./dist/markdown/*.d.ts",
      "default": "./dist/markdown/*.js"
    },
    "./node/*": {
      "import": "./dist/node/*.js",
      "types": "./dist/node/*.d.ts",
      "default": "./dist/node/*.js"
    },
    "./object/*": {
      "import": "./dist/object/*.js",
      "types": "./dist/object/*.d.ts",
      "default": "./dist/object/*.js"
    },
    "./regex/*": {
      "import": "./dist/regex/*.js",
      "types": "./dist/regex/*.d.ts",
      "default": "./dist/regex/*.js"
    },
    "./string/*": {
      "import": "./dist/string/*.js",
      "types": "./dist/string/*.d.ts",
      "default": "./dist/string/*.js"
    },
    "./testing/*": {
      "import": "./dist/testing/*.js",
      "types": "./dist/testing/*.d.ts",
      "default": "./dist/testing/*.js"
    },
    "./types/*": {
      "import": "./dist/types/*.js",
      "types": "./dist/types/*.d.ts",
      "default": "./dist/types/*.js"
    },
    "./url/*": {
      "import": "./dist/url/*.js",
      "types": "./dist/url/*.d.ts",
      "default": "./dist/url/*.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "devDependencies": {
    "jsdom": "catalog:*",
    "vitest": "catalog:*"
  }
}
