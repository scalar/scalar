{
  "name": "@scalar/icons",
  "description": "Scalar Icons",
  "license": "MIT",
  "author": "Scalar (https://github.com/scalar)",
  "homepage": "https://github.com/scalar/scalar",
  "bugs": "https://github.com/scalar/scalar/issues/new/choose",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scalar/scalar.git",
    "directory": "packages/icons"
  },
  "version": "0.7.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "generate:icons": "tsx ./scripts/generate-icons.ts",
    "lint:check": "pnpm lint:icons",
    "lint:icons": "svglint src/library/icons/*.svg --config src/library/.svglintrc.js",
    "test": "vitest",
    "types:check": "vue-tsc --noEmit"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    },
    "./library": {
      "import": "./dist/library/index.js",
      "require": "./dist/library/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "dependencies": {
    "@phosphor-icons/core": "^2.1.1",
    "@types/node": "catalog:*",
    "chalk": "^5.4.1",
    "vue": "catalog:*"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "catalog:*",
    "@vue/test-utils": "catalog:*",
    "jsdom": "catalog:*",
    "svglint": "^4.1.2",
    "vite": "catalog:*",
    "vite-svg-loader": "catalog:*",
    "vitest": "catalog:*"
  }
}
