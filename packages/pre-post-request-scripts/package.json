{
  "name": "@scalar/pre-post-request-scripts",
  "description": "Execute pre-request and post-response scripts in the Scalar API Client",
  "license": "MIT",
  "author": "Scalar (https://github.com/scalar)",
  "homepage": "https://github.com/scalar/scalar",
  "bugs": "https://github.com/scalar/scalar/issues/new/choose",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scalar/scalar.git",
    "directory": "packages/pre-post-request-scripts"
  },
  "keywords": [
    "scalar",
    "openapi",
    "swagger",
    "scripts",
    "pre-request scripts",
    "post-response scripts",
    "api client"
  ],
  "version": "0.3.16",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "dev": "vite",
    "preview": "vite preview",
    "test": "vitest",
    "types:check": "vue-tsc --noEmit"
  },
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*.css": {
      "import": "./dist/*.css",
      "require": "./dist/*.css",
      "default": "./dist/*.css"
    },
    "./plugins": {
      "import": "./dist/plugins/index.js",
      "types": "./dist/plugins/index.d.ts",
      "default": "./dist/plugins/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.4",
    "@scalar/helpers": "workspace:*",
    "@headlessui/vue": "catalog:*",
    "@scalar/components": "workspace:*",
    "@scalar/oas-utils": "workspace:*",
    "postman-sandbox": "^6.5.0",
    "vue": "catalog:*",
    "@types/postman-collection": "^3.5.11",
    "postman-collection": "^5.2.0",
    "@scalar/workspace-store": "workspace:*"
  },
  "devDependencies": {
    "@scalar/types": "workspace:*",
    "@scalar/use-codemirror": "workspace:*",
    "@vitejs/plugin-vue": "catalog:*",
    "@vue/test-utils": "catalog:*",
    "vite": "catalog:*"
  }
}
