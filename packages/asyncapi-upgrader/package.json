{
  "name": "@scalar/asyncapi-upgrader",
  "description": "Upgrade AsyncAPI documents to the latest and greatest version",
  "license": "MIT",
  "author": "Scalar (https://github.com/scalar)",
  "homepage": "https://github.com/scalar/scalar",
  "bugs": "https://github.com/scalar/scalar/issues/new/choose",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scalar/scalar.git",
    "directory": "packages/asyncapi-upgrader"
  },
  "keywords": [
    "asyncapi",
    "scalar",
    "parser",
    "typescript",
    "upgrade",
    "asyncapi 2.6",
    "asyncapi 3.0",
    "asyncapi 3.1"
  ],
  "version": "0.1.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "test": "vitest --run",
    "types:check": "tsgo --noEmit"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./1.2-to-2.6": {
      "import": "./dist/1.2-to-2.6/index.js",
      "types": "./dist/1.2-to-2.6/index.d.ts",
      "default": "./dist/1.2-to-2.6/index.js"
    },
    "./2.6-to-3.0": {
      "import": "./dist/2.6-to-3.0/index.js",
      "types": "./dist/2.6-to-3.0/index.d.ts",
      "default": "./dist/2.6-to-3.0/index.js"
    },
    "./3.0-to-3.1": {
      "import": "./dist/3.0-to-3.1/index.js",
      "types": "./dist/3.0-to-3.1/index.d.ts",
      "default": "./dist/3.0-to-3.1/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "readme": {
    "title": "Scalar AsyncAPI Upgrader",
    "badges": [
      {
        "type": "npm-version"
      },
      {
        "type": "npm-downloads"
      },
      {
        "type": "npm-license"
      }
    ],
    "documentation": "https://scalar.com/tools/asyncapi-upgrader/getting-started"
  },
  "sideEffects": false,
  "dependencies": {
    "@scalar/helpers": "workspace:*"
  },
  "devDependencies": {
    "@scalar/types": "workspace:*",
    "vite": "catalog:*"
  }
}
