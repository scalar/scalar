        "parameters": [
          {
            "description": "This is just a user identifier",
            "example": "476587598",
            "in": "path",
            "name": "user_id",
            "required": true,
            "schema": {
              "type": "number",
            },
          },
          {
            "description": "This is just a user type",
            "examples": {
              "Default example": {
                "value": "user",
                "x-disabled": false,
              },
            },
            "in": "path",
            "name": "type",
            "required": true,
            "schema": {
              "type": "string",
            },
          },
        ],
        "summary": "Get all users with description and params with type",
      },
    },
    "/users/{user_id}": {
      "get": {
        "description": "Obtain a list of users that fullfill the conditions of the filters",
        "parameters": [
          {
            "in": "path",
            "name": "user_id",
            "required": true,
            "schema": {
              "type": "string",
            },
          },
        ],
        "summary": "Get one users info",
      },
    },
  },
  "servers": [
    {
      "url": "https://api.example.com",
    },
  ],
}
`;

