exports[`fixtures > FormData 1`] = `
{
  "info": {
    "description": "Just a collection with a form data post for test",
    "title": "Form Data",
    "version": "1.0.0",
  },
  "openapi": "3.1.0",
  "paths": {
    "/register": {
      "post": {
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "examples": {
                "Default example": {
                  "value": [
                    {
                      "description": "full name of the user (accepts spaces) [required]",
                      "key": "name",
                      "type": "text",
                      "value": "New User",
                    },
                    {
                      "description": "email of the user (for notifications and login) [required]",
                      "key": "email",
                      "type": "text",
                      "value": "newuser@example.com",
                    },
                    {
                      "key": "password",
                      "type": "text",
                      "value": "super-secret-password",
                    },
                    {
                      "contentType": "application/octet-stream",
                      "description": "User avatar",
                      "key": "profileImage",
                      "src": [],
                      "type": "file",
                    },
                  ],
                },
              },
              "schema": {
                "properties": {
                  "email": {
                    "description": "email of the user (for notifications and login)",
                    "example": "newuser@example.com",
                    "type": "string",
                  },
                  "name": {
                    "description": "full name of the user (accepts spaces)",
                    "example": "New User",
                    "type": "string",
                  },
                  "password": {
                    "example": "super-secret-password",
                    "type": "string",
                  },
                  "profileImage": {
                    "description": "User avatar",
                    "format": "binary",
                    "type": "string",
                  },
                },
                "required": [
                  "name",
                  "email",
                ],
                "type": "object",
              },
            },
          },
        },
        "summary": "Register New User",
      },
    },
  },
  "servers": [
    {
      "url": "https://api.example.com",
    },
  ],
}
`;

