{
  "name": "@scalar/oas-utils",
  "description": "Open API spec and Yaml handling utilities",
  "license": "MIT",
  "author": "Scalar (https://github.com/scalar)",
  "homepage": "https://github.com/scalar/scalar",
  "bugs": "https://github.com/scalar/scalar/issues/new/choose",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scalar/scalar.git",
    "directory": "packages/oas-utils"
  },
  "keywords": [
    "oas",
    "fetching",
    "specification",
    "yaml"
  ],
  "version": "0.13.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "test": "vitest --run",
    "types:check": "tsc --noEmit"
  },
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "exports": {
    "./helpers": {
      "import": "./dist/helpers/index.js",
      "types": "./dist/helpers/index.d.ts",
      "default": "./dist/helpers/index.js"
    },
    "./migrations": {
      "import": "./dist/migrations/index.js",
      "types": "./dist/migrations/index.d.ts",
      "default": "./dist/migrations/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@scalar/helpers": "workspace:*",
    "@scalar/themes": "workspace:*",
    "@scalar/types": "workspace:*",
    "@scalar/workspace-store": "workspace:*",
    "flatted": "catalog:*",
    "github-slugger": "catalog:*",
    "vue": "catalog:*",
    "yaml": "catalog:*"
  },
  "devDependencies": {
    "@types/node": "catalog:*",
    "fake-indexeddb": "catalog:*",
    "vite": "catalog:*",
    "vitest": "catalog:*"
  }
}
