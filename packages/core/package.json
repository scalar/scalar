      "default": "./dist/libs/html-rendering/index.js"
    },
    "./libs/de-serialize-parameter": {
      "import": "./dist/libs/de-serialize-parameter/index.js",
      "types": "./dist/libs/de-serialize-parameter/index.d.ts",
      "default": "./dist/libs/de-serialize-parameter/index.js"
    },
    "./libs/serialize-parameter": {
      "import": "./dist/libs/serialize-parameter/index.js",
      "types": "./dist/libs/serialize-parameter/index.d.ts",
      "default": "./dist/libs/serialize-parameter/index.js"
    },
    "./libs/get-example": {
      "import": "./dist/libs/get-example/index.js",
      "types": "./dist/libs/get-example/index.d.ts",
      "default": "./dist/libs/get-example/index.js"
    },
    "./libs/get-resolved-ref-deep": {
      "import": "./dist/libs/get-resolved-ref-deep/index.js",
