<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
  </PropertyGroup>

  <PropertyGroup>
    <Title>Scalar.Azure.Functions</Title>
    <Description>Generate beautiful interactive API documentation from OpenAPI/Swagger documents in Azure Functions (isolated worker).</Description>
  </PropertyGroup>

  <PropertyGroup>
    <!-- We use this to conditionally include code from the shared project -->
    <DefineConstants>$(DefineConstants);SCALAR_AZURE_FUNCTIONS</DefineConstants>
  </PropertyGroup>

  <PropertyGroup>
    <StaticAssetsLogicalNamePrefix>ScalarStaticAssets</StaticAssetsLogicalNamePrefix>
    <StandaloneJavaScriptFile>../../../../../packages/api-reference/dist/browser/standalone.js</StandaloneJavaScriptFile>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="../../../shared/src/Scalar.Shared/**/*.cs" Exclude="../../../shared/src/Scalar.Shared/obj/**/*" Link="shared/%(RecursiveDir)%(Filename)%(Extension)" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Azure.Functions.Worker.Extensions.Http" />
    <PackageReference Include="Microsoft.Azure.Functions.Worker.Extensions.Http.AspNetCore" />
    <PackageReference Include="NetEscapades.EnumGenerators.Generators" PrivateAssets="all" ExcludeAssets="runtime" NoWarn="NU5104" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\README.md">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>

  <ItemGroup>
    <!-- Include compressed files for Release -->
    <!-- Import .gz files without extension so the original filename is used "scalar.js.gz" -> "scalar.js" -->
    <EmbeddedResource Include="StaticAssets/*.gz" Condition="'$(Configuration)' == 'Release'">
      <LogicalName>$(StaticAssetsLogicalNamePrefix).%(Filename)</LogicalName>
    </EmbeddedResource>

    <!-- Include uncompressed files for Debug -->
    <EmbeddedResource Include="StaticAssets/*.js;StaticAssets/*.svg" Exclude="StaticAssets/*test.js" Condition="'$(Configuration)' == 'Debug'">
      <LogicalName>$(StaticAssetsLogicalNamePrefix).%(Filename)%(Extension)</LogicalName>
    </EmbeddedResource>

    <EmbeddedResource Include="$(StandaloneJavaScriptFile)" Condition="'$(Configuration)' == 'Debug' And !Exists('StaticAssets/scalar.js') And Exists('$(StandaloneJavaScriptFile)')">
      <LogicalName>$(StaticAssetsLogicalNamePrefix).scalar.js</LogicalName>
    </EmbeddedResource>

    <!-- Fall back to uncompressed files in Release when the compression step has not generated .gz assets. -->
    <EmbeddedResource Include="StaticAssets/*.js;StaticAssets/*.svg" Exclude="StaticAssets/*test.js" Condition="'$(Configuration)' == 'Release'">
      <LogicalName>$(StaticAssetsLogicalNamePrefix).Uncompressed.%(Filename)%(Extension)</LogicalName>
    </EmbeddedResource>

    <EmbeddedResource Include="$(StandaloneJavaScriptFile)" Condition="'$(Configuration)' == 'Release' And !Exists('StaticAssets/scalar.js') And !Exists('StaticAssets/scalar.js.gz') And Exists('$(StandaloneJavaScriptFile)')">
      <LogicalName>$(StaticAssetsLogicalNamePrefix).Uncompressed.scalar.js</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

</Project>
