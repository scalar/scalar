{
  "name": "@scalar-internal/release-notes-generator",
  "version": "0.0.0",
  "description": "Generate AI-written release notes from a CHANGELOG and append them to the package RELEASE_NOTES.md",
  "type": "module",
  "private": true,
  "license": "MIT",
  "bin": {
    "release-notes-generator": "src/cli.ts"
  },
  "scripts": {
    "start": "tsx src/cli.ts",
    "test": "vitest --run",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "@scalar/helpers": "workspace:*",
    "commander": "catalog:*",
    "zod": "catalog:*"
  },
  "devDependencies": {
    "@types/node": "catalog:*",
    "tsx": "catalog:*",
    "vitest": "catalog:*"
  }
}
